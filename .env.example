# Copy to .env and fill in what you use. Everything is optional —
# Tier 1 (skills only) needs none of these.

# --- Literature search (idea triage, citation verification) ---
# Semantic Scholar: higher rate limits with a key (free at api.semanticscholar.org)
S2_API_KEY=
# SerpAPI: Google Scholar access for novelty checks (mind your plan's daily quota)
SERPAPI_KEY=

# --- Pipeline email notifications + escalation reply-back (skipped if unset) ---
MAESTRO_NOTIFY_EMAIL=
# IMAP host for reading your replies to escalation mails
# (default: SMTP host with imap. prefix)
MAESTRO_IMAP_HOST=
# Escalation token lifetime in hours; expired tokens are never read
MAESTRO_ESC_TTL_HOURS=24
MAESTRO_SMTP_HOST=
# SSL port; the notify scripts use SMTP_SSL, so keep 465 unless you edit them
MAESTRO_SMTP_PORT=465
MAESTRO_SMTP_USER=
MAESTRO_SMTP_PASS=

# --- Multi-machine tier only (see docs/advanced.md) ---
# Root of your project workspace on the control host
PROJECT_ROOT=
# Shared resource directories on your GPU host (inventory check reads these)
MODELS_DIR=
DATA_DIR=
ENVS_DIR=
# Workspace root on the remote GPU host
REMOTE_ROOT=
